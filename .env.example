# Copy to .env and fill in real values
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/reviews_intelligence
SECRET_KEY=change-me-to-32-random-chars-minimum
GOOGLE_PAGESPEED_API_KEY=
PDF_DIR=/pdfs
SCREENSHOTS_DIR=/screenshots

# Residential proxy (provider-agnostic). When set, a scan that comes back
# blocked is retried once through this proxy — most datacenter-IP blocks clear
# from a residential IP. Leave blank to disable (blocked scans stay 'blocked').
# Format: http://user:pass@host:port
PROXY_URL=

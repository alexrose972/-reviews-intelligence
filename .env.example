# Copy to .env and fill in real values
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/reviews_intelligence
SECRET_KEY=change-me-to-32-random-chars-minimum
GOOGLE_PAGESPEED_API_KEY=
PDF_DIR=/pdfs
SCREENSHOTS_DIR=/screenshots

# Scrapfly unblocker API. When set, ALL scanning goes through Scrapfly (no
# Playwright, no proxy) — it handles JS rendering + anti-bot (Cloudflare/
# PerimeterX/DataDome) server-side. Get a key at scrapfly.io (free tier ~1,000
# renders/mo). This is the recommended way to beat blockers on Railway.
SCRAPFLY_KEY=

# Residential proxy (provider-agnostic) — only used when SCRAPFLY_KEY is unset.
# A scan that comes back blocked is retried once through this proxy.
# Format: http://user:pass@host:port
PROXY_URL=
